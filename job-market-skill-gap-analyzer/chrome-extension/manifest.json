{
  "manifest_version": 3,
  "name": "SkillScope - Smart Job Application Assistant",
  "version": "1.0.0",
  "description": "AI-powered job application assistant that analyzes your resume against job postings and provides skill gap insights with personalized learning recommendations.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.prosple.com/*",
    "https://prosple.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://glassdoor.com/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://www.prosple.com/graduate-jobs/*",
        "https://prosple.com/graduate-jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://indeed.com/viewjob*",
        "https://www.glassdoor.com/job-listing/*",
        "https://glassdoor.com/job-listing/*",
        "https://www.naukri.com/job-listings-*",
        "https://naukri.com/job-listings-*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/panel.html", "content/panel.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
