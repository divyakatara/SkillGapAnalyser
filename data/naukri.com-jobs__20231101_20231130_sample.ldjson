{"uniq_id":"1bd922139e0817039b660bde351a9e9d","crawl_timestamp":"2023-11-01 12:54:51 +0000","job_title":"Voice & Accent Trainer","post_date":"2023-11-01","job_description":"Job Description Voice & Accent Trainer Requirements: Developing and implementing training programs that are aligned with business objectives, including design and development of curriculum, materials, and assessmentsPresenting training sessions that are engaging and interactive to help participants retain informationConducting needs assessments to understand what employees already know and what they need to learn nextMeasuring the effectiveness of training programs by conducting evaluations with participants and managers after a course has been completedCoordinating with other members of the organizations training department to develop and deliver training programsProviding individualized instruction to employees who need help mastering new skills or improving existing skills in order to perform their jobs more effectivelyCreating resources to support learning objectives such as handouts, workbooks, PowerPoint presentations, videos, or podcastsLeading group discussions and providing guidance on effective communication skills to increase productivity and efficiency within a team or organizationConducting training sessions in person or online using web conferencing tools such as Microsoft TeamsSkills: Education: GraduateMust be aware of Voice & Accent TrainerExperience required: 4-5 years in Training.Minimum 1+ year as Voice & Accent TrainerExcellent Oral & Written communicationConfident, articulate, and professional speaking abilities (and experience) Location: NagpurInterested candidates can share CV to tejalm@hexaware.com ","company_name":"Hexaware Technologies","url":"https://www.naukri.com/job-listings-011123007779","category":"Training","city":"Nagpur","job_type":"fulltime","company_description":"Hexaware BPS. is the wholly owned subsidiary of Hexaware Technologies Ltd. We are currently staffed at 4000+ people across Navi Mumbai (Mahape) Chennai, Nagpur US, Mexico and Russia. Hexaware BPS leverages on a strong technology legacy from its parent organization. With an amalgamation of passionate employees, innovative services and delighted customers, Hexaware the fastest growing automation-led, next-generation providers of IT, BPO and consulting services, has been revolutionizing the traditional IT approach by addressing discontinuities in the market. Our multi-pronged strategy consisting of robotic process automation, hyper-converged technology, design thinking, rapid prototyping and customized service offerings has enabled global companies to address various business issues with pointed and effective business strategies.","salary_offered":"₹ 600000-700000","job_board":"Naukri","html_job_description":"<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\" \"http://www.w3.org/TR/REC-html40/loose.dtd\"><html><body><p>  <strong>Job Description Voice & Accent Trainer</strong></p><br/><p>  <strong>Requirements:</strong></p><ul><li>Developing and implementing training programs that are aligned with business objectives, including design and development of curriculum, materials, and assessments</li><li>Presenting training sessions that are engaging and interactive to help participants retain information</li><li>Conducting needs assessments to understand what employees already know and what they need to learn next</li><li>Measuring the effectiveness of training programs by conducting evaluations with participants and managers after a course has been completed</li><li>Coordinating with other members of the organizations training department to develop and deliver training programs</li><li>Providing individualized instruction to employees who need help mastering new skills or improving existing skills in order to perform their jobs more effectively</li><li>Creating resources to support learning objectives such as handouts, workbooks, PowerPoint presentations, videos, or podcasts</li><li>Leading group discussions and providing guidance on effective communication skills to increase productivity and efficiency within a team or organization</li><li>Conducting training sessions in person or online using web conferencing tools such as Microsoft Teams</li></ul><br/><p>  <strong>Skills:</strong></p><ul><li>Education: Graduate</li><li>Must be aware of Voice & Accent Trainer</li><li>Experience required: 4-5 years in Training.</li><li>Minimum 1+ year as Voice & Accent Trainer</li><li>Excellent Oral & Written communication</li><li>Confident, articulate, and professional speaking abilities (and experience)<br/> </li></ul><p>  <strong>Location:</strong></p><ul>  <li>Nagpur</li></ul><br/><p>  <strong>    <u>Interested candidates can share CV to tejalm@hexaware.com</u>  </strong></p></body></html>","is_remote":false,"inferred_salary_from":600000.0,"inferred_salary_to":700000.0,"inferred_salary_currency":"INR","inferred_min_experience":2,"inferred_max_experience":3,"contact_email":"tejalm@hexaware.com","site_name":"naukri_com_job_board_common_setup_pc_jobspikr","domain":"naukri_com","postdate_yyyymmdd":"20231101","predicted_language":"en","inferred_iso3_lang_code":"eng","inferred_salary_time_unit":null,"has_expired":false,"last_expiry_check_date":"2023.11.01","latest_expiry_check_date":"2023-11-01","dataset":["job_board"],"postdate_in_indexname_format":"2023.11.01","segment_name":"naukri_com_job_board_common_setup_pc_jobspikr-20231101_125051941561680__20231101080136","job_desc_char_count":1549,"ijp_reprocessed_flag_1":"2023-11-01","ijp_reprocessed_flag_2":"2023-11-01","ijp_reprocessed_flag_3":"2023-11-01","duplicate_status":"NA","ijp_is_production_ready":false,"additional_data":null,"fitness_score":7}
{"uniq_id":"f60239100c0e8a4aa910791e06396b13","crawl_timestamp":"2023-11-01 12:53:59 +0000","job_title":"Systems Architect","post_date":"2023-11-01","job_description":" Global Shared Services Center  Systems Architect Job Purpose Our Client Shared Services Center is looking for a highly motivated individual to provide systems design and support and potentially to additional regions at later date.  This position requires a proactive and dynamic person with solutions development experience in the legal and finance realms. In addition, experience in leveraging the full Microsoft Stack to provide solutions for a variety of business requirements is necessary. A strong interest and ability to learn new systems and continuous improvement is a must, as well as sufficient soft skills necessary to interact appropriately and effectively with the different members of the Law Department and other parties involved in the assigned activities. One of the main responsibilities of this role is to design/manage/troubleshoot our in-house matter management system, LOIS. Responsibilities Define, develop, and refine business processes involving legal department workgroups (Litigation, L&E, M&A,etc) as well groups outside legal (Finance, QA, Product Analysis, Risk Management) which leverage our investments in LOIS (Office 365, Microsoft SQL, .Net, Power Platform, DevOps, Azure, SQL Reporting Services (SSRS)).Provide system administration support for bill processing and matter management. Provide LOIS orientation and training for new teammates. Create and modify existing reports for Legal, Risk Management, Global Legal OpsWork with outside counsel on submitting invoices electronically.Submit help desk tickets for issues involving the department and provide general help desk assistance. Requirements & Qualifications Expertise in:.Net Winform development using VB.NET and C#Relation Database Design using Microsoft SQL Server, Transact SQLSharepoint integration using CSOM- preferred , not a must Web UI/UX, AngularJS, Bootstrap, Power Automate, Power Apps.Excel AutomationSQL Reporting Services (SSRS)Microsoft 365Basic accounting skills. Fluent in English and able to communicate clearly across all levels of the organizationDetail-oriented, self-motivated, proactive & hardworking.Ability to listen, anticipate, troubleshootProven ability to meet deadlines and adapt to changing prioriti","company_name":"Headhunter","url":"https://www.naukri.com/job-listings-011123007969","category":"Other","city":"Pune","job_type":"fulltime","company_description":"Our Client is a UK based MNC, Global shared services of a Tier1 Automotive Supplier</strong></p>Candidates can apply online .(hariharan@headhunterindia.com)</strong></p>Driving Excellence in Executive Search, Job Search , Outplacement and Learning & Development. Successful track record with Global & Indian firms.</strong></p>We are providing services to clients in India, Middle East , Australia, Africa, Poland, UK, Germany and Switzerland.</strong></p>Assuring 100% Success rates in Executive Search.</strong></p>Managed High level searches for</strong></p>Information Technology Sectors</strong>.Automobile</strong>• Automotive/Auto-components</strong>• Engineering / Engineering Services</strong>• FMCG / FOOD</strong>• Pharma, Chemicals / Oil & Gas</strong>. Engineering & Metals</strong>• Plastics and Paint</strong>• Electronics & SemiconductorsWell reputed European MNC.</strong></li></ul>","salary_offered":"₹ 1000000-2000000","job_board":"Naukri","html_job_description":"<!DOCTYPE html PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\" \"http://www.w3.org/TR/REC-html40/loose.dtd\"><html><body><p> </p><p>  <strong>Global Shared Services Center </strong></p><br/><p>  <strong>Systems Architect</strong></p><br/><p>  <strong>Job Purpose</strong></p><br/><p>Our Client Shared Services Center is looking for a highly motivated individual to provide systems design and support and potentially to additional regions at later date. </p><br/><p>This position requires a proactive and dynamic person with solutions development experience in the legal and finance realms. In addition, experience in leveraging the full Microsoft Stack to provide solutions for a variety of business requirements is necessary. A strong interest and ability to learn new systems and continuous improvement is a must, as well as sufficient soft skills necessary to interact appropriately and effectively with the different members of the Law Department and other parties involved in the assigned activities. One of the main responsibilities of this role is to design/manage/troubleshoot our in-house matter management system, LOIS.</p><br/><p>  <strong>Responsibilities</strong></p><br/><ul><li>Define, develop, and refine business processes involving legal department workgroups (Litigation, L&E, M&A,etc) as well groups outside legal (Finance, QA, Product Analysis, Risk Management) which leverage our investments in LOIS (Office 365, Microsoft SQL, .Net, Power Platform, DevOps, Azure, SQL Reporting Services (SSRS)).</li><li>Provide system administration support for bill processing and matter management. </li><li>Provide LOIS orientation and training for new teammates. </li><li>Create and modify existing reports for Legal, Risk Management, Global Legal Ops</li><li>Work with outside counsel on submitting invoices electronically.</li><li>Submit help desk tickets for issues involving the department and provide general help desk assistance. </li></ul><br/><p>  <strong>Requirements & Qualifications</strong></p><br/><ul><li>Expertise in:</li><li>.Net Winform development using VB.NET and C#</li><li>Relation Database Design using Microsoft SQL Server, Transact SQL</li><li>Sharepoint integration using CSOM- preferred , not a must </li><li>Web UI/UX, AngularJS, Bootstrap, Power Automate, Power Apps.</li><li>Excel Automation</li><li>SQL Reporting Services (SSRS)</li><li>Microsoft 365</li><li>Basic accounting skills. </li><li>Fluent in English and able to communicate clearly across all levels of the organization</li><li>Detail-oriented, self-motivated, proactive & hardworking.</li><li>Ability to listen, anticipate, troubleshoot</li><li>Proven ability to meet deadlines and adapt to changing prioriti</li></ul><br/></body></html>","is_remote":false,"inferred_salary_from":1000000.0,"inferred_salary_to":2000000.0,"inferred_salary_currency":"INR","inferred_min_experience":4,"inferred_max_experience":6,"site_name":"naukri_com_job_board_common_setup_pc_jobspikr","domain":"naukri_com","postdate_yyyymmdd":"20231101","predicted_language":"en","inferred_iso3_lang_code":"eng","inferred_city":"Pune","inferred_state":"Maharashtra","inferred_country":"India","inferred_salary_time_unit":null,"has_expired":false,"last_expiry_check_date":"2023.11.01","latest_expiry_check_date":"2023-11-01","dataset":["job_board"],"postdate_in_indexname_format":"2023.11.01","segment_name":"naukri_com_job_board_common_setup_pc_jobspikr-20231101_125051941561680__20231101080136","job_desc_char_count":2227,"ijp_reprocessed_flag_1":"2023-11-01","ijp_reprocessed_flag_2":"2023-11-01","ijp_reprocessed_flag_3":"2023-11-01","duplicate_status":"NA","ijp_is_production_ready":false,"additional_data":null,"fitness_score":10}
